# Rate Limiting (Upstash Redis — for AI endpoint protection)
UPSTASH_REDIS_REST_URL=https://your-upstash-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# SuperAdmin Bootstrap (never exposed to the client — server-only)
# Must match SUPERADMIN_PASSWORD used when running: npx tsx src/scripts/seed-superadmin-only.ts
# After first login the bootstrap password is replaced; rotate this value if you re-seed.
SUPERADMIN_EMAIL=admin@yourdomain.com
SUPERADMIN_PASSWORD=your-bootstrap-password-here
SUPERADMIN_BOOTSTRAP_PASSWORD=your-bootstrap-password-here
SUPERADMIN_NAME=Super Admin

# Sprint B — MEAL Automation
KOBO_WEBHOOK_SECRET=your-32-char-secret-here
CRON_SECRET=your-32-char-secret-here